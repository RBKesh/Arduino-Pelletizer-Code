/* * Arduino Controller for Open Source Recycled Plastic Pelletizer
 * Description: Controls two stepper motors for plastic pelletizing, 
 * monitors a safety limit switch, and provides status via an OLED display.
 */

#include <Stepper.h> 
#include <Wire.h> 
#include <Adafruit_GFX.h> 
#include <Adafruit_SSD1306.h> 

// --- Stepper Motor Configuration ---
const int stepsPerRevolution = 2048; // Standard steps for 28BYJ-48 stepper motors
int motSpeed = 15;                   // Motor speed in RPM
int motDir = 1;                     // Motor direction (1 for forward, -1 for reverse)

// Initialize Stepper One on pins 8, 10, 9, 11 (Standard sequence for ULN2003 driver)
Stepper myStepperOne(stepsPerRevolution, 8, 10, 9, 11); 
// Initialize Stepper Two on pins 4, 5, 6, 7
Stepper myStepperTwo(stepsPerRevolution, 4, 5, 6, 7); 

// --- Pin Definitions ---
int Limitswitch = 2;   // Safety limit switch or "Case" sensor
int REDLED = 13;       // Indicator LED for error/off status
int dt = 500;          // Delay constant (unused in current loop logic)

// --- OLED Display Configuration ---
#define SCREEN_WIDTH 128 
#define SCREEN_HEIGHT 64 
#define OLED_RESET -1       // Reset pin (share Arduino reset pin)
#define SCREEN_ADDRESS 0x3C // I2C address for 128x64 OLED
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET); 

void setup() { 
  Serial.begin(9600); 

  // Setup Hardware Pins
  myStepperOne.setSpeed(motSpeed); 
  myStepperTwo.setSpeed(motSpeed); // Ensure second motor also has speed set
  pinMode(Limitswitch, INPUT); 
  pinMode(REDLED, OUTPUT); 

  // Initialize OLED hardware
  if (!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) { 
    Serial.println(F("SSD1306 allocation failed")); 
    while (1); // Halt if display is not found
  } 

  // Startup Splash Screen
  display.clearDisplay(); 
  display.setTextSize(1); 
  display.setTextColor(SSD1306_WHITE); 
  display.setCursor(0, 0); 
  display.println(F("GME12864-11")); 
  display.println(F("OLED Ready")); 
  display.display(); 
  delay(2000); 

  // Initial Diagnostic Graphics
  display.clearDisplay(); 
  display.drawRect(0, 0, 128, 64, SSD1306_WHITE); 
  display.drawLine(0, 0, 127, 63, SSD1306_WHITE); 
  display.drawLine(127, 0, 0, 63, SSD1306_WHITE); 
  display.display(); 
} 

void loop() { 
  // Read safety switch state
  int State = digitalRead(Limitswitch); 

  if (State == HIGH) { 
    // --- RUNNING STATE ---
    // Drive both motors simultaneously (1 step at a time for sync)
    myStepperOne.step(motDir * 1); 
    myStepperTwo.step(motDir * 1); 

    // Non-blocking OLED update (every 200ms) to prevent motor stutter
    static unsigned long lastDisplay = 0; 
    if (millis() - lastDisplay > 200) { 
      lastDisplay = millis(); 

      display.clearDisplay(); 
      display.setCursor(0, 0); 
      display.println(F("Status: Running!")); 
      display.display(); 
      
      digitalWrite(REDLED, LOW); // Turn off warning LED
    } 
  } 
  else { 
    // --- STOPPED/ERROR STATE ---
    display.clearDisplay(); 
    display.setCursor(0, 0); 
    display.println(F("Status: OFF!")); 
    display.println(F("Check Case!")); 
    display.display();  

    digitalWrite(REDLED, HIGH); // Light up warning LED
    // Note: Motors effectively stop because the .step() commands are skipped
  } 
}
